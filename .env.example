# FireCrawl API Configuration
# Get your API key at: https://www.firecrawl.dev/
# Copy this file to .env and add your actual API key

FIRECRAWL_API_KEY=your-api-key-here

# Optional: FireCrawl configuration
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Optional: Other API keys (for future extensions)
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# Note: Never commit the actual .env file to version control!
# .env should be in your .gitignore
